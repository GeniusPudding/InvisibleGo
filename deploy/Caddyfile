# Caddy reverse proxy for the InvisibleGo web server.
#
# Caddy terminates TLS (auto Let's Encrypt) and forwards HTTP + WebSocket
# to the `invisiblego` container on port 8000. The hostname `invisiblego`
# works because docker-compose creates an internal DNS entry for each
# service, reachable by service name from other containers on the same
# network.
#
# --- WITH A DOMAIN (recommended for public) ---
# 1. Point an A record at this host's public IP.
# 2. Replace `game.example.com` with your domain.
# 3. docker compose up -d  (or `docker compose restart caddy` if stack is running)
# 4. First request takes a few seconds while ACME provisions the cert.

game.example.com {
    reverse_proxy invisiblego:8000
    encode gzip
    log {
        output stdout
        format json
    }
}

# --- IP-ONLY / HTTP FALLBACK (first-time smoke test before DNS) ---
# Comment the block above and uncomment this to serve HTTP on :80.
# Browsers accept ws:// over http:// for same-origin, so the game works,
# but there is no encryption — don't leave this on in production.
#
# :80 {
#     reverse_proxy invisiblego:8000
# }
